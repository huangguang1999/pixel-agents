{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pixel-agents",
  "version": "0.1.0",
  "identifier": "com.pixel-agents.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pixel Agents Office",
        "width": 640,
        "height": 385,
        "minWidth": 336,
        "minHeight": 352,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "backgroundColor": "#11081a"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../scripts/claude-hook-forward.py": "scripts/claude-hook-forward.py",
      "../scripts/codex-hook-forward.py": "scripts/codex-hook-forward.py",
      "../scripts/grok-hook-forward.py": "scripts/grok-hook-forward.py"
    }
  }
}
